# Copy to .env.test (gitignored) — used by run_tests.py only.
# Production automation (GitHub Actions / run.ps1) does NOT load this file.

# --- Required: copy of the production Google Sheet (File → Make a copy) ---
# URL looks like: https://docs.google.com/spreadsheets/d/THIS_PART/edit
SPREADSHEET_ID=your_test_spreadsheet_id_here

# Optional tab name if not auto-detected
# SHEET_TAB=Test

# --- Layer 2+: duplicate Squarespace site URL (not the live Tribe site) ---
# Squarespace: Settings → Developer Tools → duplicate site, or use a trial site.
BASE_URL=https://your-duplicate-site.squarespace.com

# Optional: only process one pending row per test run
# TEST_ROW_LIMIT=1

# Optional: visible browser on Mac (Layer 2)
# HEADLESS=false
